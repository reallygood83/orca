        await navigator.clipboard.writeText(text);
        toast("클립보드에 복사됨");
      } catch {
        toast("복사 실패 — 텍스트를 직접 선택하세요");
      }
    }

    document.querySelectorAll(".tab").forEach((btn) => {
      btn.addEventListener("click", () => {
        document.querySelectorAll(".tab").forEach((b) => b.classList.remove("active"));
        document.querySelectorAll(".panel").forEach((p) => p.classList.remove("active"));
        btn.classList.add("active");
        $("panel-" + btn.dataset.tab).classList.add("active");
      });
    });

    function shortWorkerLabel(v) {
      if (v.workers && v.workers.length) return workerSummary(v.workers);
      return v.workerLabel || labels[v.worker] || v.worker || "실무";
    }

    FIELD_IDS.forEach((id) => {
      const el = $(id);
      if (!el) return;
      el.addEventListener("input", refresh);
      el.addEventListener("change", refresh);
    });

    wireWorkerPool();

    $("btnCopyQuick").onclick = () => copyText($("outQuick").value);
    $("btnCopyPlaybook").onclick = () => copyText($("outPlaybook").value);
    $("btnCopyShell").onclick = () => copyText($("installShell").textContent);
    $("btnCopyAi").onclick = () => copyText($("installAiPrompt").textContent);

    const SITE_URL = "https://orca-lime.vercel.app";
    const INSTALL_ONE = `curl -fsSL ${SITE_URL}/setup-mode-pack.sh | bash`;
    const SHARE_BLURB =
`Orca 조율 모드 만들기 (무료)
${SITE_URL}

[웹] 탭 3에서 모드 만들기 → 탭 4 설치
[스킬] 터미널 한 줄:
${INSTALL_ONE}

그다음 에이전트에게: /orchestration-mode  또는  조율 모드 만들기

※ 각자 자기 컴퓨터에 설치. 제작자 PC 설정 불필요.`;

    function downloadUrl(url, filename) {
      const a = document.createElement("a");
      a.href = url;
      a.download = filename || "";
      a.target = "_blank";
      a.rel = "noopener";
      document.body.appendChild(a);
      a.click();
      a.remove();
      toast("다운로드: " + filename);
    }

    if ($("btnCopySite")) $("btnCopySite").onclick = () => copyText(SITE_URL);
    if ($("btnCopyShare")) $("btnCopyShare").onclick = () => copyText(SHARE_BLURB);
    if ($("btnCopyInstall")) $("btnCopyInstall").onclick = () => copyText(INSTALL_ONE);
    if ($("btnCopySkillOne")) $("btnCopySkillOne").onclick = () => copyText(INSTALL_ONE);
    if ($("btnDlSkillMd")) $("btnDlSkillMd").onclick = () =>
      downloadUrl(SITE_URL + "/skills/orca-mode-pack/SKILL.md", "SKILL.md");
    if ($("btnDlRequest")) $("btnDlRequest").onclick = () =>
      downloadUrl(SITE_URL + "/skills/orca-mode-pack/references/REQUEST.template.md", "REQUEST.template.md");
    if ($("btnCopySkillEngine")) $("btnCopySkillEngine").onclick = () =>
      copyText($("skillEngine").textContent);
    if ($("btnCopySkillShare")) $("btnCopySkillShare").onclick = () =>
      copyText($("skillShareBlurb").textContent);
    if ($("btnCopyInstallEngine")) $("btnCopyInstallEngine").onclick = () =>
      copyText(
        INSTALL_ONE +
          "\n\n# 엔진 (PC당 1회)\nnpx skills add https://github.com/stablyai/orca --skill orchestration\nnpx skills add https://github.com/stablyai/orca --skill orca-cli\n"
      );
    if ($("btnGoSkill")) {
      $("btnGoSkill").onclick = () => {
        document.querySelectorAll(".tab").forEach((b) => b.classList.remove("active"));
        document.querySelectorAll(".panel").forEach((p) => p.classList.remove("active"));
        const tab = document.querySelector('.tab[data-tab="skill"]');
        if (tab) tab.classList.add("active");
        const panel = $("panel-skill");
        if (panel) panel.classList.add("active");
        panel && panel.scrollIntoView({ behavior: "smooth", block: "start" });
      };
    }

    $("btnDownload").onclick = () => {
      const v = vals();
      const blob = new Blob([buildDownloadPack(v)], { type: "text/markdown;charset=utf-8" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `${v.modeName}-orchestration-pack.md`;
      a.click();
      URL.revokeObjectURL(a.href);
      toast(`${v.displayName} 팩 다운로드`);
    };

    wireWorkerPool();
    refresh();
  </script>
</body>
</html>
